{
  "name": "elysstay-fe",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:bdd": "tsx ./node_modules/@cucumber/cucumber/bin/cucumber.js",
    "test:bdd:dry": "tsx ./node_modules/@cucumber/cucumber/bin/cucumber.js --dry-run",
    "test:bdd:auth": "tsx ./node_modules/@cucumber/cucumber/bin/cucumber.js --tags=@auth --format=summary",
    "test:bdd:summary": "tsx ./node_modules/@cucumber/cucumber/bin/cucumber.js --format=summary",
    "test:bdd:json": "tsx ./node_modules/@cucumber/cucumber/bin/cucumber.js --format json:tests/bdd/reports/report.json",
    "test:bdd:buildings": "tsx ./node_modules/@cucumber/cucumber/bin/cucumber.js --tags=@building-management --format=summary",
    "test:bdd:contracts": "tsx ./node_modules/@cucumber/cucumber/bin/cucumber.js --tags=@contract-lifecycle --format=summary",
    "test:bdd:dashboard": "tsx ./node_modules/@cucumber/cucumber/bin/cucumber.js --tags=@dashboard --format=summary"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-slot": "^1.2.4",
    "@tanstack/react-query": "^5.90.21",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.35.2",
    "lucide-react": "^0.577.0",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.71.2",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^12.7.0",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@tanstack/react-query-devtools": "^5.91.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "jsdom": "^29.0.1",
    "msw": "^2.12.14",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.0"
  }
}
